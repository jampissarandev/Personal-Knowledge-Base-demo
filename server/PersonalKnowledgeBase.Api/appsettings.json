{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=app.db"
  },
  "JwtSettings": {
    "Issuer": "PersonalKnowledgeBase",
    "Audience": "PersonalKnowledgeBase.Client",
    "Key": "REPLACE_WITH_SECURE_KEY_AT_LEAST_32_CHARS_LONG_FOR_HS256",
    "ExpiryInDays": 7
  },
  "__production_warning__": "JwtSettings:Key MUST be overridden via env var JwtSettings__Key in production. Do not ship the default.",
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  }
}
